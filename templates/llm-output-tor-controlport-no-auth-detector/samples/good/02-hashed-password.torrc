# torrc — good: ControlPort with a real HashedControlPassword.
# (This is the literal hash output of `tor --hash-password ...`
# from the upstream docs example, used here as a syntactic stand-in.)
SocksPort 9050
ControlPort 9051
HashedControlPassword 16:872860B76453A77D60CA2BB8C1A7042072093276A3D701AD684053EC4C
DataDirectory /var/lib/tor
