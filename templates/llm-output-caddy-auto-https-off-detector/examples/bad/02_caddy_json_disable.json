{
  "apps": {
    "http": {
      "servers": {
        "edge": {
          "listen": [":443", ":80"],
          "automatic_https": {
            "disable": true
          },
          "routes": [
            {
              "match": [{"host": ["example.internal"]}],
              "handle": [{"handler": "file_server", "root": "/srv/www"}]
            }
          ]
        }
      }
    }
  }
}
