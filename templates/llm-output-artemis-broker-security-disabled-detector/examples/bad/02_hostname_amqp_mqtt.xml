<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns="urn:activemq" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <core xmlns="urn:activemq:core">
    <name>broker-amqp-public</name>
    <security-enabled>false</security-enabled>
    <acceptors>
      <acceptor name="amqp">tcp://broker.internal.example.com:5672?protocols=AMQP</acceptor>
      <acceptor name="mqtt">tcp://broker.internal.example.com:1883?protocols=MQTT</acceptor>
    </acceptors>
  </core>
</configuration>
