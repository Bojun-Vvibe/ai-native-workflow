# docker-compose .env — bootstrap admin with a real password from
# the secret manager pipeline. The operator interpolates the value
# at deploy time; placeholder list does not match.
SFTPGO_DATA_PROVIDER__DRIVER=postgres
SFTPGO_DATA_PROVIDER__NAME=sftpgo
SFTPGO_DATA_PROVIDER__HOST=10.0.0.5
SFTPGO_DATA_PROVIDER__CREATE_DEFAULT_ADMIN=1
SFTPGO_DATA_PROVIDER__DEFAULT_ADMIN_USERNAME=ops-bootstrap
SFTPGO_DATA_PROVIDER__DEFAULT_ADMIN_PASSWORD=Q3pX8!eB2nWv-Zf6tHy0K9dR4LmUaCsJgPrM7
SFTPGO_HTTPD__BINDINGS__0__PORT=8080
SFTPGO_HTTPD__BINDINGS__0__ADDRESS=127.0.0.1
