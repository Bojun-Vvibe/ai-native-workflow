# docker-compose .env for SFTPGo — default admin baked in
SFTPGO_DATA_PROVIDER__DRIVER=sqlite
SFTPGO_DATA_PROVIDER__NAME=/srv/sftpgo/sftpgo.db
SFTPGO_DATA_PROVIDER__CREATE_DEFAULT_ADMIN=1
SFTPGO_DATA_PROVIDER__DEFAULT_ADMIN_USERNAME=admin
SFTPGO_DATA_PROVIDER__DEFAULT_ADMIN_PASSWORD=password
SFTPGO_HTTPD__BINDINGS__0__PORT=8080
SFTPGO_HTTPD__BINDINGS__0__ADDRESS=0.0.0.0
