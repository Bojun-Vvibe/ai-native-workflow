FROM cockroachdb/cockroach:v23.2.4
EXPOSE 26257 8080
COPY certs/ /cockroach/certs/
# Production-shaped: TLS certs mounted, secure mode is the default
# when --insecure is absent.
CMD ["cockroach", "start-single-node", "--certs-dir=/cockroach/certs", "--listen-addr=0.0.0.0:26257", "--http-addr=0.0.0.0:8080"]
