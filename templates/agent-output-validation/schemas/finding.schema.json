{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding",
  "description": "A single investigation finding from a sub-agent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "summary", "priority", "evidence"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier; e.g. 'F-001'."
    },
    "summary": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
