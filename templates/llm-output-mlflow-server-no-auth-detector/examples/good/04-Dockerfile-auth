FROM python:3.11-slim
RUN pip install --no-cache-dir mlflow==2.10.0 mlflow[auth]
WORKDIR /app
ENV BACKEND_URI=sqlite:////app/mlflow.db
ENV ARTIFACT_ROOT=/app/mlruns
EXPOSE 5000
CMD ["mlflow", "server", "--host", "0.0.0.0", "--port", "5000", "--app-name", "basic-auth", "--backend-store-uri", "sqlite:////app/mlflow.db", "--default-artifact-root", "/app/mlruns"]
