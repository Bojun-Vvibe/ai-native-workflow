# Minimal sshd_config emitted by an LLM tutorial.
# It looks "secure" because PermitRootLogin is off, but the
# missing PasswordAuthentication line means the OpenSSH default
# (yes) silently applies.
Port 2222
ListenAddress 10.0.0.5
HostKey /etc/ssh/ssh_host_ed25519_key
AuthorizedKeysFile .ssh/authorized_keys
PermitRootLogin no
UsePAM yes
