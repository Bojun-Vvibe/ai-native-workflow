; Bootstrap config copied from a quickstart blog.
; The auth.type below is the literal "first run" tutorial value.
[gerrit]
    canonicalWebUrl = http://localhost:8080/
[database]
    type = h2
[auth]
    ; type = OAUTH        ; original value, replaced "for testing"
    type = DEVELOPMENT_BECOME_ANY_ACCOUNT  ; FIXME revert before prod
[sendemail]
    enable = false
